local function renderItemESP()
    if not state.itemESP then hideAllItemDrawings(); return end

    local camPos
    local screenCX, screenBY = 400, 600
    do
        local ok, cam = pcall(function() return workspace.CurrentCamera end)
        if ok and cam then
            local okP, p = pcall(function() return cam.Position end)
            if okP then camPos = p end
            local okV, vp = pcall(function() return cam.ViewportSize end)
            if okV and vp then
                screenCX = math.floor(vp.x * 0.5)
                screenBY = vp.y
            end
        end
    end

    local root    = getRootPart()
    local rootPos = root and root.Position
    local seenThisFrame = {}
    local rendered = 0

    for _, obj in ipairs(state.itemCache) do
        if rendered >= state.maxRenderedItems then break end
        if obj.Parent then
            local okP, wpos = pcall(resolveWorldPosition, obj)
            if okP and wpos then
                local okW, spos, onScreen = pcall(WorldToScreen, wpos)
                if okW and onScreen and spos then
                    local bundle = getOrCreateItemBundle(obj)
                    seenThisFrame[obj] = true
                    rendered = rendered + 1

                    local color = state.itemColors[obj.Name] or Color3.fromRGB(255, 255, 255)

                    local dist = camPos and distance3D(camPos, wpos) or 80
                    local h = math.max(12, math.min(80, 1200 / math.max(dist, 1)))
                    local w = h * 0.75

                    bundle.box.Color = color
                    bundle.box.Thickness = 2
                    bundle.box.Size = Vector2.new(w, h)
                    bundle.box.Position = Vector2.new(spos.X - w * 0.5, spos.Y - h * 0.5)
                    bundle.box.Visible = state.espShowBox

                    bundle.nameText.Text = obj.Name
                    bundle.nameText.Color = color
                    bundle.nameText.Position = Vector2.new(spos.X, spos.Y - h * 0.5 - 14)
                    bundle.nameText.Visible = state.espShowName

                    if rootPos then
                        local d = math.floor(distance3D(wpos, rootPos))
                        bundle.distText.Text = d .. " studs"
                        bundle.distText.Color = color
                        bundle.distText.Position = Vector2.new(spos.X, spos.Y + h * 0.5 + 2)
                        bundle.distText.Visible = state.espShowDistance
                    else
                        bundle.distText.Visible = false
                    end

                    bundle.tracer.Color = color
                    bundle.tracer.From = Vector2.new(screenCX, screenBY)
                    bundle.tracer.To = Vector2.new(spos.X, spos.Y)
                    bundle.tracer.Visible = state.espShowTracers
                end
            end
        end
    end

    for instance, bundle in pairs(itemDrawings) do
        if not seenThisFrame[instance] then
            if instance.Parent then
                bundle.box.Visible = false; bundle.nameText.Visible = false
                bundle.distText.Visible = false; bundle.tracer.Visible = false
            else
                bundle.box:Remove(); bundle.nameText:Remove()
                bundle.distText:Remove(); bundle.tracer:Remove()
                itemDrawings[instance] = nil
            end
        end
    end
end


