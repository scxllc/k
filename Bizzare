local primOffset = 328
local rotOffset  = 192

local function getLookAtMatrix(fromPos, toPos)
    local dx, dy, dz = toPos.X - fromPos.X, toPos.Y - fromPos.Y, toPos.Z - fromPos.Z
    local zx, zy, zz = -dx, -dy, -dz
    local zmag = math.sqrt(zx*zx + zy*zy + zz*zz)
    if zmag == 0 then return {1, 0, 0, 0, 1, 0, 0, 0, 1} end
    zx, zy, zz = zx/zmag, zy/zmag, zz/zmag
    local ux, uy, uz = 0, 1, 0
    if math.abs(zy) > 0.9999 then ux, uy, uz = 0, 0, 1 end
    local xx, xy, xz = uy*zz - uz*zy, uz*zx - ux*zz, ux*zy - uy*zx
    local xmag = math.sqrt(xx*xx + xy*xy + xz*xz)
    xx, xy, xz = xx/xmag, xy/xmag, xz/xmag
    local yx, yy, yz = zy*xz - zz*xy, zz*xx - zx*xz, zx*xy - zy*xx
    return {xx, yx, zx, xy, yy, zy, xz, yz, zz}
end

local function lookAtStep()
    if not state.npcKillerEnabled then return end
    local lp = player
    if not lp or not lp.Character then return end
    local myHrp = lp.Character:FindFirstChild("HumanoidRootPart")
    if not myHrp then return end
    local target = state.raidTarget
    if not target or not target.Parent then return end
    local targetPos = target:FindFirstChild("HumanoidRootPart")
        and target.HumanoidRootPart.Position
        or resolveWorldPosition(target)
    if not targetPos then return end
    local mat  = getLookAtMatrix(myHrp.Position, targetPos)
    local addr = tonumber(myHrp.Address)
    if not addr or addr == 0 then return end
    local prim = memory_read("uintptr_t", addr + primOffset)
    if not prim or prim == 0 then return end
    for i = 1, 9 do
        memory_write("float", prim + rotOffset + ((i - 1) * 4), mat[i])
    end
end

task.spawn(function()
    while true do
        pcall(lookAtStep)
        task.wait()
    end
end)


local function getClosestRaidNPC()
    local myChar = player.Character
    if not myChar then return nil end
    local myHRP = myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return nil end
    local liveFolder = workspace:FindFirstChild("Live")
    if not liveFolder then return nil end
    local myPos = myHRP.Position
    local closestDist, closestNPC = math.huge, nil

    for _, npc in ipairs(liveFolder:GetChildren()) do
        pcall(function()
            if npc.Name == player.Name or npc.Name == "Server" then return end
            if not npc:IsA("Model") then return end
            if npc.Name:find("ostage") then return end
            local humanoid = npc:FindFirstChild("Humanoid")
            local hrp      = npc:FindFirstChild("HumanoidRootPart")
            if humanoid and hrp and humanoid.Health > 0 then
                local d = distance3D(hrp.Position, myPos)
                if d < closestDist then
                    closestDist = d
                    closestNPC  = npc
                end
            end
        end)
    end

    return closestNPC
end

local function isRaidTargetValid(target)
    if not target or not target.Parent then return false end
    local ok, result = pcall(function()
        local humanoid = target:FindFirstChild("Humanoid")
        local hrp      = target:FindFirstChild("HumanoidRootPart")
        return humanoid and hrp and humanoid.Health > 0
    end)
    return ok and result
end

local function ensureRaidTarget()
    if not isRaidTargetValid(state.raidTarget) then
        state.raidTarget = getClosestRaidNPC()
    end
    return state.raidTarget
end


local function orbitLoop()
    while state.npcKillerEnabled and state.npcMethod == "Orbit" and not state.shouldUnload do
        pcall(function()
            local myChar = player.Character
            if not myChar then return end
            local myHRP = myChar:FindFirstChild("HumanoidRootPart")
            if not myHRP then return end
            local target = ensureRaidTarget()
            if not target then return end
            local targetHRP = target:FindFirstChild("HumanoidRootPart")
            if not targetHRP then state.raidTarget = nil; return end
            local targetPos  = targetHRP.Position
            local orbitAngle = os.clock() * state.orbitSpeed
            local offsetX    = math.cos(orbitAngle) * state.orbitRadius
            local offsetZ    = math.sin(orbitAngle) * state.orbitRadius
            pcall(function()
                myHRP.Position = Vector3.new(
                    targetPos.X + offsetX,
                    targetPos.Y,
                    targetPos.Z + offsetZ
                )
            end)
            pcall(mouse1press)
        end)
        task.wait()
    end
    pcall(mouse1release)
end

