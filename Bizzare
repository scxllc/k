local function refreshItemCache()
    local now = os.clock()
    if now - state.itemCacheLastRefresh < state.itemCacheRefreshInterval then return end
    state.itemCacheLastRefresh = now
    state.itemCache = {}
    local seenThisScan = {}

    local ok, children = pcall(function() return workspace:GetChildren() end)
    if not ok or not children then return end

    for _, child in ipairs(children) do
        if child.Name == "Model" then
            local ok2, descs = pcall(function() return child:GetDescendants() end)
            if ok2 and descs then
                for _, obj in ipairs(descs) do
                    if trackedItemLookup[obj.Name] then
                        local key = getItemAddressKey(obj)
                        if not seenThisScan[key] then
                            seenThisScan[key] = true
                            table.insert(state.itemCache, obj)
                            state.seenItemAddresses[key] = now
                            if #state.itemCache >= config.maxTrackedItems then break end
                        end
                    end
                end
            end
        end
        if #state.itemCache >= config.maxTrackedItems then break end
    end

    for key, lastSeen in pairs(state.seenItemAddresses) do
        if now - lastSeen > config.addressRetentionSeconds then
            state.seenItemAddresses[key] = nil
        end
    end

    state.itemScanInitialized = true
end

local function findTargetItem()
    local root = getRootPart()
    local rootPos = root and root.Position
    local bestInst, bestPos, bestDist = nil, nil, math.huge

    for _, obj in ipairs(state.itemCache) do
        if obj.Parent and state.collectTargetNames[obj.Name] then
            local ok, worldPos = pcall(resolveWorldPosition, obj)
            if ok and worldPos then
                local d = rootPos and distance3D(worldPos, rootPos) or 0
                if d < bestDist then
                    bestDist = d
                    bestInst = obj
                    bestPos  = worldPos
                end
            end
        end
    end

    return bestInst, bestPos
end

local function autoCollectLoop()
    state.itemCacheLastRefresh = 0
    refreshItemCache()

    local searchStart = os.clock()

    while state.autoCollect and not state.shouldUnload do
        refreshItemCache()

        local target, targetPos = findTargetItem()

        if not target or not targetPos then
            if os.clock() - searchStart >= 1.5 then
                if state.collectSafeSpot then
                    teleportTo(config.safeSpot)
                end
                task.wait(0.5)
            else
                task.wait(0.1)
            end
        else
            searchStart = os.clock()

            local pickupPos = Vector3.new(targetPos.X, targetPos.Y + 5, targetPos.Z)
            teleportTo(pickupPos)
            task.wait(0.15)
            task.wait(0.5)

            if keypress then pcall(keypress, 0x45) end
            task.wait(2.0)
            if keyrelease then pcall(keyrelease, 0x45) end

            task.wait(0.2)

            state.itemCacheLastRefresh = 0
            refreshItemCache()

            local nextTarget, _ = findTargetItem()
            if not nextTarget then
                searchStart = os.clock()
            end
        end
    end

    if keyrelease then pcall(keyrelease, 0x45) end
end

local function startAutoCollect()
    if state.collectThread then task.cancel(state.collectThread); state.collectThread = nil end
    state.collectThread = task.spawn(autoCollectLoop)
end

local function stopAutoCollect()
    if state.collectThread then task.cancel(state.collectThread); state.collectThread = nil end
    if keyrelease then pcall(keyrelease, 0x45) end
end


